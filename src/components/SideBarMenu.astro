---
import { Icon } from "astro-icon/components";
const { sideBarActiveItemID } = Astro.props;
---

<ul class="menu grow shrink menu-md overflow-y-auto">
    <li>
        <a class={`py-3 text-base font-bold ${sideBarActiveItemID === "home" ? "active-nav" : ""}`} href="/">
            <Icon name="tabler:home" class="w-5 h-5" /> Home
        </a>
    </li>
    <li>
        <a class={`py-3 text-base font-bold ${sideBarActiveItemID === "blog" ? "active-nav" : ""}`} href="/blog/">
            <Icon name="tabler:pencil" class="w-5 h-5" /> Blog
        </a>
    </li>
    <li>
        <a class={`py-3 text-base font-bold ${sideBarActiveItemID === "about" ? "active-nav" : ""}`} href="/about">
            <Icon name="tabler:user" class="w-5 h-5" /> About
        </a>
    </li>
    <li>
        <a class={`py-3 text-base font-bold ${sideBarActiveItemID === "projects" ? "active-nav" : ""}`} href="/projects">
            <Icon name="tabler:folder" class="w-5 h-5" /> Projects
        </a>
    </li>
    <li>
        <a class={`py-3 text-base font-bold ${sideBarActiveItemID === "cv" ? "active-nav" : ""}`} href="/cv">
            <Icon name="tabler:file-cv" class="w-5 h-5" /> CV
        </a>
    </li>
    <li>
        <a
            class={`py-3 text-base font-bold ${sideBarActiveItemID === "contact" ? "active-nav" : ""}`}
            href="/contact">
            <Icon name="tabler:mail" class="w-5 h-5" />
            Contact
        </a>
    </li>
</ul>
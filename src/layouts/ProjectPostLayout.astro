---
import BaseLayout from "./BaseLayout.astro";
import { Image } from "astro:assets";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";

export interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  heroImage?: string;
  tags?: string[];
  projectUrl?: string;
  repoUrl?: string;
}

const {
  title,
  description,
  pubDate,
  heroImage,
  tags = [],
  projectUrl,
  repoUrl,
} = Astro.props;

dayjs.extend(localizedFormat);
const displayDate = dayjs(pubDate).format("ll");
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  sideBarActiveItemID="projects"
  ogType="article"
>
  <main class="md:flex md:justify-center">
    <article class="prose prose-lg max-w-[750px] prose-img:mx-auto w-full">

      <!-- Date -->
      <time class="text-sm opacity-60">{displayDate}</time>

      <!-- Title -->
      <h1 class="text-4xl font-bold mt-2 mb-3">{title}</h1>

      <!-- Description -->
      {description && (
        <p class="text-lg opacity-70 mt-0 mb-6 not-prose">
          {description}
        </p>
      )}

      <!-- Hero Image -->
      {heroImage && (
        <div class="not-prose mb-8 rounded-md overflow-hidden">
          <Image
            width={750}
            height={400}
            format="webp"
            src={heroImage}
            alt={title}
            class="w-full max-h-[400px] object-cover"
          />
        </div>
      )}

      <!-- Project Links -->
      {(projectUrl || repoUrl) && (
        <div class="flex flex-wrap gap-3 mt-5 mb-8 not-prose">
          {projectUrl && (
            <a
              href={projectUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="active-nav px-4 py-2 font-medium no-underline transition-colors"
            >
              View Project
            </a>
          )}

          {repoUrl && (
            <a
              href={repoUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="active-nav px-4 py-2 font-medium no-underline transition-colors"
            >
              View Code
            </a>
          )}
        </div>
      )}

      <div class="divider my-2"></div>

      <slot />

    </article>
  </main>
</BaseLayout>
<style>
  .active-nav {
    background-color: rgba(245, 166, 35, 0.1);
    color: #F5A623;
    border-radius: 0.5rem;
  }

  .active-nav:hover {
    background-color: rgba(245, 166, 35, 0.15);
  }
</style>
---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SideBar from "../components/SideBar.astro";
import { ViewTransitions } from "astro:transitions";
import { Icon } from "astro-icon/components";

import { SITE_TITLE, SITE_DESCRIPTION, TRANSITION_API } from "../config";

const {
  image,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  includeSidebar = true,
  sideBarActiveItemID,
  ogType,
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="business">
<head>

  <!-- this theme script prevents toggle theme flashing-->
  <script is:inline>
    (() => {
      const DARK_THEME = "business";
      const LIGHT_THEME = "cupcake";
      const STORAGE_KEY = "theme";

      const savedTheme = localStorage.getItem(STORAGE_KEY);
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;

      const theme = savedTheme || (prefersDark ? DARK_THEME : LIGHT_THEME);
      document.documentElement.setAttribute("data-theme", theme);
    })();
  </script>

  <BaseHead title={title} description={description} image={image} ogType={ogType} />
  {TRANSITION_API && <ViewTransitions />}

    <!-- Style for clickable images-->
    <style is:global>
        .image-lightbox {
        background: oklch(var(--b1));
        border: none;
        border-radius: 0.75rem;
        width: 80vw;
        max-width: 80vw;
        max-height: 90vh;
        padding: 1.5rem;
        position: fixed;
        }

      .image-lightbox::backdrop {
        background: rgba(0, 0, 0, 0.7);
      }

    .image-lightbox-close {
        position: absolute;
        top: 0.75rem;
        right: 0.75rem;
        background: none;
        border: none;
        color: oklch(var(--bc));
        cursor: pointer;
        padding: 0.25rem;
    }

    .image-lightbox figcaption {
        color: oklch(var(--bc));
        text-align: center;
        margin-top: 0.75rem;
        font-size: 0.9rem;
    }

    .image-lightbox img {
    width: 100%;
    max-height: 75vh;
    object-fit: contain;
    border-radius: 0.5rem;
    display: block;
    }
  </style>
</head>

<body>

  <div class="max-w-6xl mx-auto relative">
  <button
    id="theme-toggle"
    class="absolute top-4 right-4 z-50 btn btn-circle btn-sm"
    aria-label="Toggle theme"
  >
    <Icon name="tabler:sun" id="icon-sun" class="w-5 h-5" />
    <Icon name="tabler:moon" id="icon-moon" class="w-5 h-5 hidden" />
  </button>

      <div class="bg-base-100 drawer lg:drawer-open">
        <input id="my-drawer" type="checkbox" class="drawer-toggle" />
        <div class="drawer-content bg-base-100">
          <Header title={SITE_TITLE} />
          <div class="md:flex md:justify-center">
            <main class="p-6 pt-10 lg:max-w-[900px] max-w-[100vw]">
              <slot />
            </main>
          </div>
          <Footer />
        </div>
        {includeSidebar && <SideBar sideBarActiveItemID={sideBarActiveItemID} />}
      </div>

    <!-- Lightbox -->
    <!-- dont think in need
    <dialog id="lightbox" style="background:rgba(0,0,0,0.85); border:none; max-width:90vw; max-height:90vh; padding:0;">
      <button id="lightbox-close" style="position:fixed; top:1rem; right:1rem; background:none; border:none; color:white; font-size:2rem; cursor:pointer;">✕</button>
      <figure style="margin:0; padding:1rem;">
        <img id="lightbox-img" style="max-width:85vw; max-height:80vh; object-fit:contain;" alt="" />
        <figcaption id="lightbox-caption" style="color:white; text-align:center; margin-top:0.5rem;"></figcaption>
      </figure>
    </dialog>
    -->

      <!-- Clickable Images -->
      <dialog
      class="image-lightbox"
      data-image-lightbox
      aria-label="Expanded image"
  >
      <button
          class="image-lightbox-close"
          type="button"
          data-image-lightbox-close
          aria-label="Close expanded image"
      >
          <Icon name="tabler:x" class="w-6 h-6" />
      </button>
      <figure>
          <img data-image-lightbox-img alt="" decoding="async" />
          <figcaption data-image-lightbox-caption></figcaption>
      </figure>
  </dialog>

    <script is:inline>
    function setupLightbox() {
      const lightbox = document.querySelector("[data-image-lightbox]");
      const lightboxImage = document.querySelector("[data-image-lightbox-img]");
      const lightboxCaption = document.querySelector("[data-image-lightbox-caption]");
      const lightboxClose = document.querySelector("[data-image-lightbox-close]");

      const getCaption = (image) => {
        const figureCaption = image.closest("figure")?.querySelector("figcaption")?.textContent;
        return figureCaption?.trim() || image.alt || "";
      };

      const openLightbox = (image) => {
        if (!lightbox || !lightboxImage || !lightboxCaption) return;
        lightboxImage.src = image.currentSrc || image.src;
        lightboxImage.alt = image.alt || "";
        const caption = getCaption(image);
        lightboxCaption.textContent = caption;
        lightboxCaption.hidden = !caption;
        lightbox.showModal();
        lightboxClose?.focus();
      };

      document.querySelectorAll(".prose img").forEach((image) => {
        if (image.closest("a")) return;
        image.dataset.lightboxImage = "true";
        image.tabIndex = 0;
        image.setAttribute("role", "button");
        image.setAttribute("aria-label", image.alt ? `Expand image: ${image.alt}` : "Expand image");
        image.style.cursor = "zoom-in";
        image.addEventListener("click", () => openLightbox(image));
        image.addEventListener("keydown", (event) => {
          if (event.key !== "Enter" && event.key !== " ") return;
          event.preventDefault();
          openLightbox(image);
        });
      });

      lightboxClose?.addEventListener("click", () => lightbox?.close());
      lightbox?.addEventListener("click", (event) => {
        if (event.target === lightbox) lightbox.close();
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") lightbox?.close();
      });
    }

    setupLightbox();
    document.addEventListener("astro:page-load", setupLightbox);
  </script>


    <!-- admin login via netlify -->
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
          if (
            !user &&
            (
              window.location.hash.includes("invite_token") ||
              window.location.hash.includes("recovery_token") ||
              window.location.hash.includes("confirmation_token")
            )
          ) {
            window.netlifyIdentity.open();
          }
        });

        window.netlifyIdentity.on("login", () => {
          if (window.location.pathname !== "/admin/") {
            document.location.href = "/admin/";
          }
        });
      }
    </script>

  <!-- Toggle Dark and Light modes-->
  <script is:inline>
    const DARK_THEME = "business";
    const LIGHT_THEME = "cupcake";
    const STORAGE_KEY = "theme";

    function getSavedTheme() {
      const savedTheme = localStorage.getItem(STORAGE_KEY);
      if (savedTheme) return savedTheme;

      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      return prefersDark ? DARK_THEME : LIGHT_THEME;
    }

    function applyTheme(theme) {
      document.documentElement.setAttribute("data-theme", theme);

      const sun = document.getElementById("icon-sun");
      const moon = document.getElementById("icon-moon");

      if (sun && moon) {
        if (theme === DARK_THEME) {
          sun.classList.remove("hidden");
          moon.classList.add("hidden");
        } else {
          sun.classList.add("hidden");
          moon.classList.remove("hidden");
        }
      }
    }

    function setupThemeToggle() {
      applyTheme(getSavedTheme());

      const button = document.getElementById("theme-toggle");
      if (!button) return;

      button.onclick = () => {
        const current =
          document.documentElement.getAttribute("data-theme") || DARK_THEME;

        const next = current === DARK_THEME ? LIGHT_THEME : DARK_THEME;

        localStorage.setItem(STORAGE_KEY, next);
        applyTheme(next);
      };
    }

    setupThemeToggle();

    document.addEventListener("astro:page-load", setupThemeToggle);

    document.addEventListener("astro:before-swap", event => {
      const theme = getSavedTheme();
      event.newDocument.documentElement.setAttribute("data-theme", theme);
    });
  </script>


  </body>
</html>

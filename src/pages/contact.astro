---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" sideBarActiveItemID="contact">
  <main class="md:flex md:justify-center">
    <article class="prose prose-lg max-w-[750px] w-full">

      <h1 class="text-4xl font-bold mb-3">Contact Me</h1>

      <p class="text-lg opacity-70 mt-0 mb-8 not-prose">
        Have a question, project idea, or opportunity? Send me a message below.
      </p>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/contact-success"
        class="not-prose space-y-5"
      >
        <input type="hidden" name="form-name" value="contact" />

        <p class="hidden">
          <label>
            Don’t fill this out if you’re human:
            <input name="bot-field" />
          </label>
        </p>

        <div>
          <label for="name" class="block font-medium mb-2">Name</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            class="input input-bordered w-full"
          />
        </div>

        <div>
          <label for="email" class="block font-medium mb-2">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="input input-bordered w-full"
          />
        </div>

        <div>
          <label for="message" class="block font-medium mb-2">Message</label>
          <textarea
            id="message"
            name="message"
            rows="7"
            required
            class="textarea textarea-bordered w-full"
          ></textarea>
        </div>

        <button type="submit" class="active-nav px-5 py-3 font-medium">
          Send Message
        </button>
      </form>

    </article>
  </main>
</BaseLayout>
